# APIs
# For local dev, use /api to proxy through Next.js (avoids CORS)
# For production, use full URL like https://api.keadatabase.nz
NEXT_PUBLIC_API_BASE=/api

# Backend API base URL for Next.js proxy (development only)
# This is the actual backend URL that Next.js will proxy requests to
BACKEND_API_BASE=https://dev.data.keadatabase.nz

# WordPress CMS
NEXT_PUBLIC_WORDPRESS_BASE=https://public-api.wordpress.com/wp/v2/sites/blog.keadatabase.nz

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN= # Mapbox API token for basemap tiles
NEXT_PUBLIC_LINZ_API_KEY= # LINZ API key for topographic layers (optional)
