# APIs
# Path the app calls. Use /api so requests route through the Next.js proxy
# (dev: src/app/api/[...path]/route.ts) or the Vercel rewrite (prod), both of
# which forward to the backend and rewrite Set-Cookie for same-origin auth.
NEXT_PUBLIC_API_PATH=/api

# Backend the proxy forwards to. API_BASE is used by vercel.json in production;
# BACKEND_API_BASE is used by the Next.js dev proxy route.
API_BASE=https://dev.data.keadatabase.nz
BACKEND_API_BASE=https://dev.data.keadatabase.nz

# WordPress CMS
NEXT_PUBLIC_WORDPRESS_BASE=https://public-api.wordpress.com/wp/v2/sites/blog.keadatabase.nz

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN= # Mapbox API token for basemap tiles
NEXT_PUBLIC_LINZ_API_KEY= # LINZ API key for topographic layers (optional)
