SENTRY_DSN=put_sentry_api_key_here

# Production email (Mailgun via anymail). Leave blank locally to use SMTP/console.
MAILGUN_API_KEY=put_mailgun_sending_key_here

# Local email: point at an SMTP catcher (ddev Mailpit listens on :1025).
# EMAIL_HOST=localhost
# EMAIL_PORT=1025

# Frontend base URL used in allauth verification / password-reset email links.
FRONTEND_URL=http://localhost:3000

# Extra dev hosts/origins (comma-separated), added to ALLOWED_HOSTS /
# CSRF_TRUSTED_ORIGINS when DEBUG. localhost is always allowed.
# DEV_ALLOWED_HOSTS=.ddev.site
# DEV_CSRF_TRUSTED_ORIGINS=https://*.ddev.site
